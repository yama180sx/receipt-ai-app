generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 家族構成
model FamilyMember {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  receipts Receipt[]
}

// 費目カテゴリー（キーワード判定機能付き）
model Category {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  keywords Json     @default("[]") // PostgreSQLのJSONBとして保存
  items    Item[]
}

// 店舗正規化マスタ
model Store {
  id           Int      @id @default(autoincrement())
  officialName String   @unique
  aliases      Json     @default("[]") // PostgreSQLのJSONBとして保存
}

model Receipt {
  id          Int          @id @default(autoincrement())
  memberId    Int
  member      FamilyMember @relation(fields: [memberId], references: [id])
  storeName   String
  date        DateTime
  totalAmount Int
  rawText     String
  items       Item[]
  createdAt   DateTime     @default(now())
}

model Item {
  id         Int      @id @default(autoincrement())
  receiptId  Int
  receipt    Receipt  @relation(fields: [receiptId], references: [id])
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  name       String
  price      Int
  quantity   Int      @default(1)
}