{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",        // NodeNext から変更
    "moduleResolution": "node",   // NodeNext から変更
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "node_modules/@types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}