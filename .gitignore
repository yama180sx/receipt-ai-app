# --- Dependencies ---
**/node_modules/
**/dist/
**/build/
.expo/
web-build/

# --- Environment Variables (Secret Info) ---
**/.env
**/.env.local
**/.env.*
.env
# .env.example はリポジトリに含めるため除外対象から外す
!**/.env.example

# --- Backend & Logging (Issue #30 対応) ---
# ログディレクトリ全体と監査ファイルを除外
backend/logs/
*.log
*-audit.json

# アップロード画像 (WebP を含む全画像形式を除外)
backend/uploads/*
!backend/uploads/.gitkeep

# --- Database & Prisma ---
postgres_data/
/backend/prisma/generated-client/
/backend/src/generated/

# --- System & IDE ---
.DS_Store
Thumbs.db
*.code-workspace
.vscode/
.idea/

# --- Misc ---
npm-debug.log*
yarn-error.log*
.serverless/
.fusebox/
.dynamodb/